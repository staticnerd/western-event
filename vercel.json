{
  "functions": {
    "pages/api/admin/sign-upload.js":    { "maxDuration": 10 },
    "pages/api/admin/confirm-upload.js": { "maxDuration": 10 },
    "pages/api/admin/test-connection.js":{ "maxDuration": 15 }
  },
  "headers": [
    {
      "source": "/admin/(.*)",
      "headers": [
        { "key": "X-Robots-Tag",   "value": "noindex, nofollow" },
        { "key": "Cache-Control",  "value": "no-store" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options",        "value": "SAMEORIGIN" }
      ]
    }
  ]
}
